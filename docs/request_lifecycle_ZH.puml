@startuml request_lifecycle
!theme plain
title AuthGate — 请求生命周期 (POST /auth/register)

actor "客户端" as Client
participant "API Gateway" as APIGW
participant "Lambda\nHandleAPIGatewayEvent" as Lambda
participant "service\nMatchRoute" as Router
participant "handler\nAuthRegister" as Handler
participant "handler\nRegistration" as Register
participant "model\nJWT" as JWT
participant "persistence\nPersistUser" as Persist
participant "DynamoDB\n/ TableStore" as DB

== API Gateway → Lambda ==
Client -> APIGW : POST /auth/register\n{"Username":"alice",...}
APIGW -> Lambda : Invoke(APIGatewayEvent)\n{httpMethod, path, headers, body}

== Event → http.Request ==
Lambda -> Lambda : http.NewRequestWithContext(\nctx, "POST", "/auth/register", body)
Lambda -> Lambda : 复制 headers
Lambda -> Router : MatchRoute("/auth/register")

== 路由分发 ==
Router -> Router : 遍历 Routes\n精确匹配 "/auth/register"
Router --> Lambda : handler.AuthRegister

== Handler ==
Lambda -> Handler : AuthRegister(w, r)
Handler -> Handler : w.Header().Set("Content-Type",\n"application/json")
Handler -> Handler : json.NewDecoder(r.Body).Decode(&user)

alt 非法请求体
    Handler -> Handler : w.WriteHeader(400)\nResponse{error:"invalid request body"}
    Handler --> Lambda : 400
    Lambda --> APIGW : apiGatewayResponse(400, resp)
    APIGW --> Client : 400 Bad Request
else 请求体 OK
    Handler -> Register : Registration(user, ip, ua)

    == 业务逻辑 ==
    Register -> Register : 校验 username/email/password

    alt 校验失败
        Register --> Handler : error
        Handler -> Handler : w.WriteHeader(500)\nResponse{error: err}
    else 校验通过
        Register -> JWT : NewAccessToken(subject, ip, ua)
        JWT --> Register : accessJWT
        Register -> JWT : accessJWT.Sign(PrivateKey)
        JWT --> Register : accessTokenStr (RS256)

        Register -> JWT : NewRefreshToken(subject, ip, ua)
        JWT --> Register : refreshJWT
        Register -> JWT : refreshJWT.Sign(PrivateKey)
        JWT --> Register : refreshTokenStr (RS256)

        Register --> Handler : JwtResponse{access, refresh, expires, actor}

        == 持久化 (best-effort) ==
        Handler -> Persist : PersistUserFunc(ctx, user, jwtResp)

        alt AWS Ready
            Persist -> DB : aws.Insert(DynamoDB, "Users", item)
        else Aliyun Ready
            Persist -> DB : aliyun.Insert(TableStore, "Users", item)
        else 无后端
            note over Persist : 静默跳过
        end

        alt 写入失败
            DB --> Persist : error
            note over Handler : 仅记日志 — 不阻塞响应\n客户端已拿到有效 JWT
        end

        Handler -> Handler : json.Encode(Response{\n200, jwtResponse})
    end
end

== 响应封装 ==
Handler --> Lambda : 写入 responseRecorder\n(statusCode + body)
Lambda -> Lambda : json.Unmarshal(w.body, &resp)\n→ model.Response
Lambda -> Lambda : apiGatewayResponse(statusCode, resp)
note right of Lambda : 注入 DefaultSecurityHeaders\n(CSP, HSTS, XFO, CORP, COEP, COOP...)
Lambda --> APIGW : {statusCode, headers, body}

APIGW -> APIGW : 解包信封
APIGW --> Client : HTTP 200\nContent-Type: application/json\n...15 个安全头...\n{"status_code":200,"data":{...}}

@enduml
